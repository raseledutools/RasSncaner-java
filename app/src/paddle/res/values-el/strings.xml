<?xml version="1.0" encoding="utf-8"?>
<!--
  Συμβολοσειρές για το backend του PaddleOCR.
  Υπάρχουν μόνο στο product flavor 'paddle' (βλ. app/build.gradle, flavorDimensions "ocr").
  Η διατήρηση αυτών των συμβολοσειρών εκτός του flavor 'standard' (F-Droid)
  αποφεύγει προειδοποιήσεις Lint για UnusedResources και μειώνει το μέγεθος
  του APK για το προεπιλεγμένο flavor.
-->
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Επιλογές: PaddleOCR backend (ορατό μόνο σε arm64-v8a + paddle flavor). -->
    <string name="opt_paddle_ocr">PaddleOCR</string>
    <string name="opt_paddle_ocr_subtitle">Καλύτερη αναγνώριση κειμένου· η επισήμανση σε επίπεδο λέξης μπορεί να είναι λιγότερο ακριβής σε σύγκριση με το Tesseract.</string>
    <string name="ocr_models_hint">Το PaddleOCR είναι ενσωματωμένο σε αυτή την έκδοση. Τα μοντέλα Tesseract δεν χρησιμοποιούνται εδώ.</string>
</resources>