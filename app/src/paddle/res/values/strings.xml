<?xml version="1.0" encoding="utf-8"?>
<!--
  Strings for the PaddleOCR backend.
  Only present in the 'paddle' product flavor (see app/build.gradle, flavorDimensions "ocr").
  Keeping these strings out of the 'standard' (F-Droid) flavor avoids
  Lint UnusedResources warnings and reduces APK size for the default flavor.
-->
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Options: PaddleOCR backend (only visible on arm64-v8a + paddle flavor). -->
    <string name="opt_paddle_ocr">PaddleOCR</string>
    <string name="opt_paddle_ocr_subtitle">Better text recognition; word-level highlighting may be less precise than with Tesseract.</string>
    <string name="ocr_models_hint">PaddleOCR is integrated in this build. Tesseract models are not used here.</string>
</resources>
