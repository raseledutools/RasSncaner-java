<?xml version="1.0" encoding="utf-8"?>
<!--
  Strings for the experimental PaddleOCR backend.
  Only present in the 'paddle' product flavor (see app/build.gradle, flavorDimensions "ocr").
  Keeping these strings out of the 'standard' (F-Droid) flavor avoids
  Lint UnusedResources warnings and reduces APK size for the default flavor.
-->
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Options: PaddleOCR experimental backend (only visible on arm64-v8a + paddle flavor).
         German translation lives in src/paddle/res/values-de/strings.xml. Other locales fall
         back to the default (English); this is intentional for an experimental backend, hence
         the MissingTranslation suppression. -->
    <string name="opt_paddle_ocr" tools:ignore="MissingTranslation">PaddleOCR (experimental)</string>
    <string name="opt_paddle_ocr_subtitle" tools:ignore="MissingTranslation">Better text recognition; word-level highlighting may be less precise than with Tesseract.</string>
</resources>
