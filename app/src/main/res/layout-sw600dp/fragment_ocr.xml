<?xml version="1.0" encoding="utf-8"?>
<!-- Tablet (sw600dp) variant: two-pane layout.
     Left pane: recognized text. Right pane: language selection, hint, actions.
     All view IDs are identical to layout/fragment_ocr.xml so OCRFragment works
     unchanged. -->
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <!-- Status / Überschrift -->
    <TextView
            android:id="@+id/text_ocr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:textColor="?android:attr/textColorPrimary"
            android:text="@string/ocr_processing_complete_tap_the_button_to_proceed_to_export"
            android:textAlignment="center"
            android:textSize="20sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Workflow stepper: Camera → Crop → OCR → Export (step 3) -->
    <de.schliweb.makeacopy.ui.views.WorkflowStepperView
            android:id="@+id/workflow_stepper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:currentStep="3"
            app:layout_constraintTop_toBottomOf="@id/text_ocr"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Vertical split between text pane (left) and controls pane (right) -->
    <androidx.constraintlayout.widget.Guideline
            android:id="@+id/pane_guideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.58" />

    <!-- OCR-Resultat — left pane -->
    <TextView
            android:id="@+id/ocr_result_text"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp"
            android:text="@string/ocr_results_will_appear_here"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="18sp"
            android:textIsSelectable="true"
            android:background="@drawable/rounded_bg_light"
            android:gravity="top|start"
            android:padding="12dp"
            android:minHeight="80dp"
            app:layout_constraintTop_toBottomOf="@id/workflow_stepper"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/pane_guideline" />

    <!-- Sprache auswählen (modern exposed dropdown) — right pane -->
    <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/language_input_layout"
            style="@style/Widget.Material3.TextInputLayout.FilledBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:hint="@string/label_language"
            app:endIconMode="dropdown_menu"
            app:layout_constraintTop_toBottomOf="@id/workflow_stepper"
            app:layout_constraintStart_toEndOf="@id/pane_guideline"
            app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/language_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:focusable="false"
                android:clickable="true"
                android:cursorVisible="false"
                android:importantForAutofill="no"
                android:dropDownVerticalOffset="8dp"
                android:dropDownHeight="wrap_content"
                android:maxLines="1"
                android:popupBackground="?attr/colorSurfaceVariant"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Hint about OCR models (Fast vs Best) — right pane -->
    <TextView
            android:id="@+id/ocr_models_hint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="8dp"
            android:text="@string/ocr_models_hint"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/language_input_layout"
            app:layout_constraintStart_toEndOf="@id/pane_guideline"
            app:layout_constraintEnd_toEndOf="parent" />

    <!-- OCR actions row: settings + review icons — right pane -->
    <LinearLayout
            android:id="@+id/ocr_actions_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="8dp"
            android:layout_marginBottom="8dp"
            app:layout_constraintStart_toEndOf="@id/pane_guideline"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/button_container">

        <ImageButton
                android:id="@+id/button_ocr_options"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginEnd="16dp"
                android:padding="8dp"
                android:contentDescription="@string/btn_options"
                android:src="@drawable/ic_tune"
                app:tint="?attr/colorControlNormal"
                android:minWidth="48dp"
                android:minHeight="48dp"
                app:tooltipText="@string/btn_options"
                android:background="?attr/selectableItemBackgroundBorderless"/>

        <ImageButton
                android:id="@+id/button_ocr_review"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"
                android:contentDescription="@string/btn_review"
                android:src="@drawable/ic_edit"
                app:tint="?attr/colorControlNormal"
                android:minWidth="48dp"
                android:minHeight="48dp"
                app:tooltipText="@string/btn_review"
                android:background="?attr/selectableItemBackgroundBorderless"/>

        <ImageButton
                android:id="@+id/button_ocr_share"
                android:enabled="false"
                android:alpha="0.4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginStart="16dp"
                android:padding="8dp"
                android:contentDescription="@string/btn_share_text"
                android:src="@drawable/ic_share"
                app:tint="?attr/colorControlNormal"
                android:minWidth="48dp"
                android:minHeight="48dp"
                app:tooltipText="@string/btn_share_text"
                android:background="?attr/selectableItemBackgroundBorderless"/>
    </LinearLayout>

    <!-- Bottom button bar — right pane -->
    <LinearLayout
            android:id="@+id/button_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:background="?attr/colorSurfaceContainer"
            android:padding="12dp"
            android:elevation="8dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/pane_guideline"
            app:layout_constraintEnd_toEndOf="parent">

        <Button
                android:id="@+id/button_back"
                style="@style/Widget.MakeACopy.Button.Tonal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/back"
                android:maxLines="1"
                android:ellipsize="end" />

        <Button
                android:id="@+id/button_process"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/next"
                android:maxLines="1"
                android:ellipsize="end" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
