<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <CheckBox
            android:id="@+id/dialog_checkbox_include_ocr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/include_ocr_text" />

        <!-- Format selection moved inline to the Export screen (segmented PDF | JPEG buttons). -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:text="@string/document_cleanup_title" />

        <RadioGroup
            android:id="@+id/dialog_document_cleanup_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/dialog_document_cleanup_original"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/document_cleanup_original" />

            <RadioButton
                android:id="@+id/dialog_document_cleanup_natural"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/document_cleanup_natural" />

            <RadioButton
                android:id="@+id/dialog_document_cleanup_enhanced"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/document_cleanup_enhanced" />

            <RadioButton
                android:id="@+id/dialog_document_cleanup_clean_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/document_cleanup_clean_text" />
        </RadioGroup>

        <!-- PDF options group (shown when NOT exporting as JPEG) -->
        <LinearLayout
            android:id="@+id/dialog_pdf_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/output_color_title" />

            <RadioGroup
            android:id="@+id/dialog_pdf_bw_mode_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

                <RadioButton
                    android:id="@+id/dialog_pdf_bw_none"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/pdf_bw_mode_none" />

                <RadioButton
                    android:id="@+id/dialog_pdf_grayscale"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/convert_to_grayscale" />

                <RadioButton
                    android:id="@+id/dialog_pdf_bw_robust"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pdf_bw_mode_robust" />

                <RadioButton
                    android:id="@+id/dialog_pdf_bw_classic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pdf_bw_mode_classic"
                    android:visibility="gone" />
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="@string/page_format_label" />

            <RadioGroup
                android:id="@+id/dialog_page_format_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/dialog_radio_page_fit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/page_format_fit" />

                <RadioButton
                    android:id="@+id/dialog_radio_page_a4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/page_format_a4" />

                <RadioButton
                    android:id="@+id/dialog_radio_page_letter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/page_format_letter" />

                <RadioButton
                    android:id="@+id/dialog_radio_page_legal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/page_format_legal" />
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="@string/pdf_text_layer_mode_title" />

            <RadioGroup
                android:id="@+id/dialog_pdf_text_layer_mode_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/dialog_pdf_text_layer_line_based"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/pdf_text_layer_mode_line_based" />

                <RadioButton
                    android:id="@+id/dialog_pdf_text_layer_word_positioned"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pdf_text_layer_mode_word_positioned" />
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="@string/dpi_settings_label" />

            <RadioGroup
                android:id="@+id/dialog_pdf_preset_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/dialog_radio_pdf_high"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pdf_preset_high" />

                <RadioButton
                    android:id="@+id/dialog_radio_pdf_standard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pdf_preset_standard" />

                <RadioButton
                    android:id="@+id/dialog_radio_pdf_small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pdf_preset_small" />

                <RadioButton
                    android:id="@+id/dialog_radio_pdf_very_small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pdf_preset_very_small" />
            </RadioGroup>
        </LinearLayout>

        <!-- JPEG options group (shown when exporting as JPEG) -->
        <LinearLayout
            android:id="@+id/dialog_jpeg_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/output_color_title" />

            <RadioGroup
                android:id="@+id/dialog_jpeg_mode_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/dialog_radio_jpeg_none"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/jpeg_mode_none" />

                <RadioButton
                    android:id="@+id/dialog_radio_jpeg_auto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/jpeg_mode_auto" />

                <RadioButton
                    android:id="@+id/dialog_radio_jpeg_bw_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/jpeg_mode_bw_text" />
            </RadioGroup>
        </LinearLayout>

        <!-- Inbox Mode -->
        <LinearLayout
            android:id="@+id/dialog_inbox_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/inbox_mode"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <CheckBox
                android:id="@+id/dialog_checkbox_inbox_enabled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/inbox_mode_enable" />

            <TextView
                android:id="@+id/dialog_inbox_folder_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/inbox_folder_none"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="4dp" />

            <!-- Stacked vertically: the long localized labels (e.g. German) wrap
                 unevenly when placed side by side -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialog_button_inbox_select"
                style="@style/Widget.MakeACopy.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/inbox_select_folder" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialog_button_inbox_clear"
                style="@style/Widget.MakeACopy.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/inbox_clear" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/inbox_filename_format"
                android:paddingTop="8dp" />

            <Spinner
                android:id="@+id/dialog_inbox_filename_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <CheckBox
                android:id="@+id/dialog_checkbox_inbox_auto_new_scan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/inbox_auto_new_scan"
                android:paddingTop="4dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
